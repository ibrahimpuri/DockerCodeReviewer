# Copy this file to .env and fill in your actual API keys.
# NEVER commit the .env file to source control.

# Required when AI Engine = GPT-4
OPENAI_API_KEY=sk-...

# Required when AI Engine = Claude
CLAUDE_API_KEY=sk-ant-...

# SQLite database path (mounted Docker volume path)
DB_PATH=./data/codelens.db

# Directory for fine-tuned model weights (mounted Docker volume path)
MODEL_WEIGHTS_DIR=./data/model_weights
