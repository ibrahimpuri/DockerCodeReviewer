# Streamlit imports ai_code_reviewer_backend directly (not via HTTP),
# so it also needs the CUDA image to run inference on the RTX 5070.
FROM pytorch/pytorch:2.6.0-cuda12.6-cudnn9-runtime

# Install Node.js + ESLint — required by the JavaScript linter in the backend
RUN apt-get update && apt-get install -y --no-install-recommends \
        nodejs npm \
    && npm install -g eslint \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt /app/
RUN pip install --no-cache-dir -r requirements.txt

COPY ai_code_reviewer_backend.py /app/
COPY streamlit_app.py /app/
COPY database.py /app/
COPY trainer.py /app/

RUN mkdir -p /app/data

# Run as a non-root user
RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser
RUN chown -R appuser:appgroup /app
USER appuser

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=10s --start-period=25s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8501/_stcore/health')"

CMD ["streamlit", "run", "streamlit_app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true"]
