# ── GPU backend selection ──────────────────────────────────────────────────────
# Streamlit imports ai_code_reviewer_backend directly (not via HTTP), so it
# also needs torch with the correct GPU backend to run inference.
#
# Build with:
#   --build-arg GPU_BACKEND=cpu     (default — works on all platforms)
#   --build-arg GPU_BACKEND=cuda    (NVIDIA, requires nvidia-container-toolkit)
#   --build-arg GPU_BACKEND=rocm    (AMD, requires ROCm drivers on Linux)
#   --build-arg GPU_BACKEND=intel   (Intel Arc/Xe, requires oneAPI on Linux)
ARG GPU_BACKEND=cpu

# ── Base images ────────────────────────────────────────────────────────────────
FROM pytorch/pytorch:2.6.0-cuda12.6-cudnn9-runtime AS base-cuda
FROM python:3.12-slim AS base-cpu
FROM python:3.12-slim AS base-rocm
FROM python:3.12-slim AS base-intel

# ── Runtime stage ──────────────────────────────────────────────────────────────
FROM base-${GPU_BACKEND} AS final
ARG GPU_BACKEND=cpu

RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_lts.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && npm install -g eslint \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN if   [ "$GPU_BACKEND" = "rocm" ];  then \
        pip install --no-cache-dir torch==2.6.0 \
            --index-url https://download.pytorch.org/whl/rocm6.2; \
    elif [ "$GPU_BACKEND" = "intel" ]; then \
        pip install --no-cache-dir torch==2.6.0 \
            --index-url https://download.pytorch.org/whl/cpu \
        && pip install --no-cache-dir intel-extension-for-pytorch; \
    elif [ "$GPU_BACKEND" = "cpu" ];   then \
        pip install --no-cache-dir torch==2.6.0 \
            --index-url https://download.pytorch.org/whl/cpu; \
    fi

COPY requirements.txt /app/
RUN pip install --no-cache-dir -r requirements.txt

COPY ai_code_reviewer_backend.py streamlit_app.py database.py trainer.py /app/

RUN mkdir -p /app/data

RUN addgroup --system appgroup \
    && adduser --system --ingroup appgroup appuser \
    && usermod -a -G video,render appuser 2>/dev/null || true
RUN chown -R appuser:appgroup /app
USER appuser

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=10s --start-period=25s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8501/_stcore/health')"

CMD ["streamlit", "run", "streamlit_app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true"]
